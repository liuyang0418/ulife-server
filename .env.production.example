# ============================================================
# 优宅养·续航智脑 生产环境配置
# 部署前逐项填写，不得提交到 Git
# ============================================================

PORT=3000
NODE_ENV=production

# ─── MySQL ───────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ulife
DB_PASSWORD=请替换为强密码_至少16位含大小写数字特殊字符
DB_NAME=ulife
DB_POOL_MIN=2
DB_POOL_MAX=20

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=请替换为Redis密码
REDIS_DB=0

# ─── JWT（生产必须换成随机长字符串）────────────────────────
JWT_SECRET=请替换为64位以上随机字符串_openssl_rand_base64_64
JWT_EXPIRES_IN=7d

# ─── CORS（前端域名，生产环境不能用 *）─────────────────────
CORS_ORIGIN=https://你的前端域名.com

# ─── 微信公众号 ────────────────────────────────────────────
WECHAT_APP_ID=你的AppID
WECHAT_APP_SECRET=你的AppSecret

# ─── 阿里云 OSS ────────────────────────────────────────────
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=ulife-videos-prod
OSS_KEY_ID=你的AccessKeyId
OSS_KEY_SECRET=你的AccessKeySecret
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
STS_ROLE_ARN=acs:ram::账号ID:role/角色名
STS_KEY_ID=STS_AccessKeyId
STS_KEY_SECRET=STS_AccessKeySecret

# ─── H5 基础路径 ──────────────────────────────────────────
H5_BASE_URL=https://你的前端域名.com
